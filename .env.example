GOOGLE_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=ieee-ai-chatbot
PINECONE_NAMESPACE=default
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_METRIC=cosine
PINECONE_DIMENSION=1024

CHAT_MODEL=gemini-2.5-flash-lite
MAX_OUTPUT_TOKENS=400
EMBEDDING_MODEL=models/gemini-embedding-001
RETRIEVER_K=5
RETRIEVER_FETCH_K=20
INTERNET_FALLBACK_ENABLED=true
WEB_SEARCH_RESULTS=5
WEB_SEARCH_TIMEOUT_SECONDS=10
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

DOCS_PDF_DIR=docs/pdf
DOCS_PPT_DIR=docs/ppt
DOCS_DOC_DIR=docs/doc
WEBSITE_DEFAULT_URL=https://ieee-mangment.vercel.app/
WEBSITE_MAX_PAGES=25
WEBSITE_TIMEOUT_SECONDS=20
MANIFEST_PATH=.rag_manifest.json

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=IEEE-AI-Chatbot
